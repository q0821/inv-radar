---
import BaseLayout from '../layouts/BaseLayout.astro';
import TickerSearch from '../components/TickerSearch.astro';

const base = import.meta.env.BASE_URL;
---
<BaseLayout title="歷史報告 - 投資訊號日報">
  <nav class="nav">
    <a href={`${base}`}>最新報告</a>
    <a href={`${base}archive/`}><strong>歷史報告</strong></a>
  </nav>

  <div class="card">
    <div class="card-body">
      <h1 class="section-title">歷史報告</h1>
      <TickerSearch />
    </div>
  </div>
</BaseLayout>
