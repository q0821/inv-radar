---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReportContent from '../../components/ReportContent.astro';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const reportFiles = import.meta.glob('../../../data/reports/*.json', { eager: true });

  return Object.entries(reportFiles).map(([path, mod]) => {
    const report = (mod as any).default;
    // Extract date from filename: ../../../data/reports/2026-03-17.json → 2026-03-17
    const fileName = path.split('/').pop()?.replace('.json', '') || '';
    return {
      params: { date: fileName },
      props: { report },
    };
  });
}

interface Props {
  report: any;
}

const { date } = Astro.params;
const { report } = Astro.props;
---
<BaseLayout title={`投資訊號日報 - ${date}`}>
  <nav class="nav">
    <a href={`${base}`}>最新報告</a>
    <a href={`${base}archive/`}>歷史報告</a>
    <span style="color:var(--c-text-muted);font-size:0.9em;">/ {date}</span>
  </nav>

  <ReportContent report={report} />
</BaseLayout>
